generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum MatchStatus {
  SCHEDULED
  IN_PLAY
  FINISHED
}

enum Winner {
  HOME
  AWAY
  DRAW
}

enum PredictionStatus {
  PENDING
  EVALUATED
}

model User {
  id           String       @id @default(uuid())
  username     String       @unique
  email        String       @unique
  passwordHash String
  role         Role         @default(USER)
  totalPoints  Int          @default(0)
  achievements Json         @default("[]") // Array of strings (e.g. 'FIRST_CORRECT', '10_STREAK')
  avatarUrl    String?
  bio          String?
  createdAt    DateTime     @default(now())
  predictions  Prediction[]
}

model Match {
  id          Int          @id // Mapped to external API Match ID
  homeTeam    String
  awayTeam    String
  homeCrest   String?
  awayCrest   String?
  startTime   DateTime
  homeScore   Int?
  awayScore   Int?
  status      MatchStatus  @default(SCHEDULED)
  minute      String?
  createdAt   DateTime     @default(now())
  predictions Prediction[]
}

model Prediction {
  id                 String           @id @default(uuid())
  user               User             @relation(fields: [userId], references: [id])
  userId             String
  match              Match            @relation(fields: [matchId], references: [id])
  matchId            Int
  predictedDifference Int
  predictedWinner    Winner
  pointsAwarded      Int              @default(0)
  status             PredictionStatus @default(PENDING)
  createdAt          DateTime         @default(now())

  @@unique([userId, matchId])
}
